# BuildLens production environment (single-VM + Docker Compose deployment).
#
#   cp .env.production.example .env.production   and fill every "REPLACE_*" value.
#
# .env.production is gitignored (see .gitignore). NEVER commit real secrets.
# Used with: docker compose --env-file .env.production -f deploy/docker-compose.prod.yml ...
# (the deploy/deploy.sh script wires this up for you).
#
# The gateway REFUSES TO BOOT in production if any of these still holds a
# placeholder or the published all-zero key, so fill them for real. Generate
# secrets with the commands noted beside each.

# ---------------------------------------------------------------------------
# Public identity (single domain; Caddy terminates TLS and routes by path)
# ---------------------------------------------------------------------------
# The domain that resolves to this VM. Frontend is served at the root; the
# gateway is reached at /auth/* and /webhooks/* on this SAME host, so the
# session cookie the gateway sets is shared with the frontend automatically.
DOMAIN=buildlens.example.com
# Email Let's Encrypt uses for certificate-expiry notices.
ACME_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# Postgres  (not published to the host; reachable only on the compose network)
# ---------------------------------------------------------------------------
POSTGRES_USER=buildlens
# openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_postgres_owner_password
POSTGRES_DB=buildlens
# Per-service least-privilege roles (created on first boot by init/01-roles.sh).
# openssl rand -base64 24   (one each)
GATEWAY_DB_PASSWORD=REPLACE_gateway_db_password
ANALYTICS_DB_PASSWORD=REPLACE_analytics_db_password
AI_DB_PASSWORD=REPLACE_ai_db_password

DATABASE_MAX_CONNECTIONS=20
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# ---------------------------------------------------------------------------
# RabbitMQ  (internal only)
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=buildlens
# openssl rand -base64 24
RABBITMQ_DEFAULT_PASS=REPLACE_rabbitmq_password
RABBITMQ_DEFAULT_VHOST=buildlens

# ---------------------------------------------------------------------------
# MinIO (S3-compatible log/artifact storage, internal only)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=buildlens
# openssl rand -base64 24  (>= 8 chars required by MinIO)
MINIO_ROOT_PASSWORD=REPLACE_minio_password
MINIO_LOGS_BUCKET=buildlens-logs
MINIO_ARTIFACTS_BUCKET=buildlens-artifacts

# ---------------------------------------------------------------------------
# Gateway (Rust / Axum)
# ---------------------------------------------------------------------------
ENVIRONMENT=production
RUST_LOG=info,buildlens_gateway=info,sqlx=warn

# GitHub App. Register a PRODUCTION app (or repoint your existing one) whose
# callback / setup / webhook URLs match the values below exactly. See DEPLOY.md.
GITHUB_CLIENT_ID=REPLACE_github_app_client_id
GITHUB_CLIENT_SECRET=REPLACE_github_app_client_secret
GITHUB_APP_ID=REPLACE_github_app_id
GITHUB_APP_SLUG=REPLACE_github_app_slug
# The PEM downloaded from GitHub, base64-encoded onto ONE line:
#   base64 -w0 your-app.private-key.pem
GITHUB_APP_PRIVATE_KEY=REPLACE_github_app_private_key_base64

# These three must point at your public domain (NOT localhost). GitHub calls the
# first and third directly; the browser follows the login link built from
# GATEWAY_PUBLIC_URL.
GITHUB_REDIRECT_URI=https://buildlens.example.com/auth/github/callback
GITHUB_WEBHOOK_URL=https://buildlens.example.com/webhooks/github
GITHUB_API_BASE_URL=https://api.github.com
# openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=REPLACE_at_least_32_random_characters

# Exactly 32 bytes, base64-encoded. Generate ONCE and never change it: rotating
# this makes every already-stored GitHub credential undecryptable.
#   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=REPLACE_base64_of_32_random_bytes
SESSION_TTL_SECONDS=604800

# ---------------------------------------------------------------------------
# AI worker (Python / FastAPI)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=REPLACE_anthropic_api_key
# openssl rand -hex 32
AI_MANUAL_TRIGGER_TOKEN=REPLACE_at_least_32_random_characters
AI_FAILURE_MODEL=claude-opus-4-8
AI_SUMMARY_MODEL=claude-haiku-4-5
AI_MONTHLY_COST_CAP_USD=25.00
AI_SUCCESS_SUMMARIES_ENABLED=false
AI_SCHEDULED_REPORTS_ENABLED=false

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
# Where the browser is sent after login/logout.
FRONTEND_URL=https://buildlens.example.com
# Server Components reach the gateway over the internal compose network.
GATEWAY_INTERNAL_URL=http://gateway:8080
# The public origin the browser uses to start sign-in (routed to the gateway by
# Caddy at /auth/*). Same host as FRONTEND_URL, so cookies are shared.
GATEWAY_PUBLIC_URL=https://buildlens.example.com
