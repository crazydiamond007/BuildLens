# BuildLens local development environment.
# Copy to .env (`make env`) and adjust. .env is gitignored; never commit real secrets.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# The owner role. The migrator connects as this; application services do not.
POSTGRES_USER=buildlens
POSTGRES_PASSWORD=buildlens_dev_password
POSTGRES_DB=buildlens
# Published on 5433, not 5432. A system-installed Postgres on the host listens on
# 5432 and would shadow the container for anything connecting from the host.
# and because Postgres reports an unknown role as "password authentication
# failed", the symptom looks like a wrong password rather than a wrong database.
# Only the HOST port moves; inside the compose network it is still 5432.
POSTGRES_PORT=5433

# Per-service login roles. Created by infra/postgres/init/01-roles.sh on first
# boot; privileges are granted in migration 000010. Each service gets write
# access only to the tables it owns.
GATEWAY_DB_PASSWORD=gateway_dev_password
ANALYTICS_DB_PASSWORD=analytics_dev_password
AI_DB_PASSWORD=ai_dev_password

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# RabbitMQ (exchange, queue, and binding topology is defined in Phase 4)
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=buildlens
RABBITMQ_DEFAULT_PASS=buildlens_dev_password
RABBITMQ_DEFAULT_VHOST=buildlens
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ---------------------------------------------------------------------------
# MinIO (S3-compatible build log + artifact storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=buildlens
MINIO_ROOT_PASSWORD=buildlens_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_LOGS_BUCKET=buildlens-logs
MINIO_ARTIFACTS_BUCKET=buildlens-artifacts

# ---------------------------------------------------------------------------
# Gateway (Rust / Axum)
# ---------------------------------------------------------------------------
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
ENVIRONMENT=development
RUST_LOG=buildlens_gateway=debug,tower_http=debug,sqlx=warn,info

# Connection string used when the gateway runs on the host (`make dev`).
# Inside docker-compose the host is `postgres`/`redis`, not `localhost`.
DATABASE_URL=postgres://buildlens_gateway:gateway_dev_password@localhost:5433/buildlens
REDIS_URL=redis://localhost:6379
DATABASE_MAX_CONNECTIONS=10
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# GitHub App. One app does everything: it authenticates the user for identity
# (client id/secret below, narrow user permissions) and authenticates itself per
# installation for repository access (App ID + private key). Register it under
# Settings -> Developer settings -> GitHub Apps; the callback, setup, and webhook
# URLs configured there must match these exactly. See the README for the full
# field-by-field checklist.
#
# The App's own OAuth client credentials, used for user sign-in.
GITHUB_CLIENT_ID=replace_with_github_app_client_id
GITHUB_CLIENT_SECRET=replace_with_github_app_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback
# Browser destination after login and logout.
FRONTEND_URL=http://localhost:3000
GITHUB_API_BASE_URL=https://api.github.com

# The App's numeric ID and its slug (the name in github.com/apps/<slug>). The
# slug builds the "install BuildLens" URL the sign-in page links to.
GITHUB_APP_ID=replace_with_github_app_id
GITHUB_APP_SLUG=replace_with_github_app_slug
# The App's private key, the PEM downloaded from GitHub. Either paste the raw
# PEM (newlines and all, quoted) or base64-encode the whole file into one line;
# the gateway accepts both. This mints installation access tokens, so it grants
# repository access to every installation - treat it like a root credential.
GITHUB_APP_PRIVATE_KEY=replace_with_github_app_private_key_pem

# GitHub must be able to reach this URL. localhost only works with a webhook
# forwarding tunnel during local development. One App-level webhook receives
# events for every installed repository; there are no per-repository hooks.
GITHUB_WEBHOOK_URL=http://localhost:8080/webhooks/github
# At least 32 random characters. Use the same value in every gateway replica.
GITHUB_WEBHOOK_SECRET=replace_with_at_least_32_random_characters

# Exactly 32 bytes, base64-encoded. This all-zero value is for local development
# only; production must inject a randomly generated secret and retain it, because
# changing it makes already stored GitHub credentials unreadable.
TOKEN_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
SESSION_TTL_SECONDS=604800

# --- Phase 4: event relay and log storage -----------------------------------

# The gateway's outbox relay publishes to this. The vhost is the path segment
# and must match RABBITMQ_DEFAULT_VHOST above.
RABBITMQ_URL=amqp://buildlens:buildlens_dev_password@localhost:5672/buildlens

# Build-log object storage. MinIO in development; a real S3 endpoint in
# production. The gateway addresses it path-style, so one hostname is enough.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=buildlens
S3_SECRET_KEY=buildlens_dev_password
S3_LOGS_BUCKET=buildlens-logs

# --- Phase 5: Java analytics ------------------------------------------------

# Spring Boot analytics when run on the host (`make analytics-dev`). Compose
# replaces the host with `postgres` while keeping the same least-privilege role.
ANALYTICS_PORT=8081
ANALYTICS_DATABASE_URL=jdbc:postgresql://localhost:5433/buildlens

# --- Phase 6: Python AI worker ---------------------------------------------

AI_PORT=8082
AI_DATABASE_URL=postgresql://buildlens_ai:ai_dev_password@localhost:5433/buildlens
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
# Protects the internal manual report re-trigger endpoint. Replace outside dev.
AI_MANUAL_TRIGGER_TOKEN=replace_with_at_least_32_random_characters
AI_FAILURE_MODEL=claude-opus-4-8
AI_SUMMARY_MODEL=claude-haiku-4-5
AI_MONTHLY_COST_CAP_USD=10.00
AI_SUCCESS_SUMMARIES_ENABLED=false
# Disabled in the example so CI/local smoke tests never spend API money merely
# by starting. Enable explicitly where scheduled daily/weekly reports are wanted.
AI_SCHEDULED_REPORTS_ENABLED=false

# --- Phase 7: Next.js frontend ---------------------------------------------

FRONTEND_PORT=3000
# Used by Server Components when the frontend runs on the host. Compose replaces
# the internal URL with http://gateway:8080 while browser OAuth links keep using
# the public URL.
GATEWAY_INTERNAL_URL=http://localhost:8080
GATEWAY_PUBLIC_URL=http://localhost:8080
